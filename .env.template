# Live service secrets are fetched from 1Password.
# Regular local development does not need this file. Run `npm run init` to
# create a local-only .dev.vars without 1Password or production credentials.
# Run `npm run setup-secrets` only when you intentionally want local dev to use
# live SES, Cloudflare Images, R2/D1-related account credentials, and Anthropic.

# Leave this as-is for local development
APP_BASE_URL=http://localhost:8787
# Local dev auth bypass: if set, auto-login as admin on localhost
DEV_ADMIN_EMAIL=dev-admin@sintlucasmasters.local
# npx wrangler whoami
CLOUDFLARE_ACCOUNT_ID={{ op://Code Space/Sint Lucas Masters/Cloudflare/CLOUDFLARE_ACCOUNT_ID }}
CLOUDFLARE_ACCOUNT_HASH={{ op://Code Space/Sint Lucas Masters/Cloudflare/CLOUDFLARE_ACCOUNT_HASH }}
# From wrangler.toml
CLOUDFLARE_DATABASE_ID={{ op://Code Space/Sint Lucas Masters/Cloudflare/CLOUDFLARE_DATABASE_ID }}
# Manage Account > Account API Tokens > Create > Custom
# Account - D1 - Edit
# Account - Cloudflare Images - Edit
# Zone - Workers Routes - Edit
CLOUDFLARE_API_TOKEN={{ op://Code Space/Sint Lucas Masters/Cloudflare/CLOUDFLARE_API_TOKEN }}
# App JWT session key
JWT_SECRET={{ op://Code Space/Sint Lucas Masters/App/JWT_SECRET }}
# AWS Simple Email Service (SES) for transactional emails
AWS_ACCESS_KEY_ID={{ op://Code Space/Sint Lucas Masters/Amazon/AWS_ACCESS_KEY_ID }}
AWS_SECRET_ACCESS_KEY={{ op://Code Space/Sint Lucas Masters/Amazon/AWS_SECRET_ACCESS_KEY }}
AWS_REGION={{ op://Code Space/Sint Lucas Masters/Amazon/AWS_REGION }}
SES_CONFIGURATION_SET=sintlucasmasters-events
# Sentry (build-time only, for source map uploads)
SENTRY_AUTH_TOKEN={{ op://Code Space/Sint Lucas Masters/Sentry/SENTRY_AUTH_TOKEN }}
SENTRY_ORG={{ op://Code Space/Sint Lucas Masters/Sentry/SENTRY_ORG }}
SENTRY_PROJECT={{ op://Code Space/Sint Lucas Masters/Sentry/SENTRY_PROJECT }}
# Anthropic (machine translations)
ANTHROPIC_API_KEY={{ op://Code Space/Sint Lucas Masters/Anthropic/ANTHROPIC_API_KEY }}
